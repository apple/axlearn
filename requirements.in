tensorflow_datasets
msgpack
portpicker
grain
array-record
tensorstore
aqtp
seqio
nltk
etils[array-types,edc,enp,epath,epy,etqdm,etree]  # pin all extras to prevent uv from splitting across lines
orbax_checkpoint
hypothesis
ml_goodput_measurement
